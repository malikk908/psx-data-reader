# Copy this file to `.env` and fill in values for local development.
# Any unset variable will fall back to a sensible default defined in code.

# MongoDB connection
FINHISAAB_MONGO_URI=mongodb://127.0.0.1:27017/
FINHISAAB_DB_NAME=finhisaab
FINHISAAB_COLLECTION=stockpricehistories

FINHISAAB_PRIMARY_DB_MONGO_URI=
FINHISAAB_PRIMARY_DB_NAME=

# Dividend announcements scraper
FINHISAAB_DIVIDEND_COLLECTION=dividendannouncements
FINHISAAB_BONUS_COLLECTION=bonusannouncements

FINHISAAB_DIVIDEND_ROWS_PER_PAGE=100
FINHISAAB_DIVIDEND_DELAY_MIN=1
FINHISAAB_DIVIDEND_DELAY_MAX=2

# Batching and throttling
# How many symbols per batch
FINHISAAB_BATCH_SIZE=10
# Maximum number of batches to process this run (set to 1 for local testing)
FINHISAAB_MAX_BATCHES=1

# Delays to avoid overload (seconds)
FINHISAAB_SYMBOL_DELAY_MIN=1
FINHISAAB_SYMBOL_DELAY_MAX=2
FINHISAAB_BATCH_DELAY_MIN=10
FINHISAAB_BATCH_DELAY_MAX=20

# Intraday quote poller
# Destination MongoDB for intraday_klines_temp collection
MONGODB_INTRADAY_URI=mongodb://127.0.0.1:27017/
MONGODB_INTRADAY_DB_NAME=finhisaab_intraday
# Seconds to sleep between symbols within a single poll cycle
INTRADAY_POLL_SYMBOL_DELAY=0.5
# Random cycle interval range — poller picks a random duration in [min, max]
# each cycle to avoid a fixed fingerprint (defaults: 90s–150s = 1.5–2.5 min)
INTRADAY_POLL_CYCLE_MIN_SECONDS=90
INTRADAY_POLL_CYCLE_MAX_SECONDS=150
# Volume-stasis holiday detection: consecutive frozen cycles before sleeping
INTRADAY_STASIS_THRESHOLD=3
# Minutes to sleep when stasis is detected (holiday / unexpected halt)
INTRADAY_HOLIDAY_RECHECK_MIN=20
